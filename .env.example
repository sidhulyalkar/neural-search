# Literature-linking API configuration (neural_search/literature/api_config.py)
#
# All variables below are optional. Sensible defaults are used when unset --
# see load_literature_api_config() for exact fallback behavior. Copy this
# file to `.env` and fill in values only if you need higher rate limits or
# a different contact address than the default.

# Used as the fallback contact address for CROSSREF_MAILTO / NCBI_TOOL_EMAIL
# below, and directly for OpenAlex's "polite pool" mailto parameter.
NEURAL_SEARCH_CONTACT_EMAIL=

# Crossref's "polite pool" mailto parameter (higher, more consistent rate
# limits). Falls back to NEURAL_SEARCH_CONTACT_EMAIL if unset. No API key
# needed -- Crossref's polite pool is free, just requires a contact email.
CROSSREF_MAILTO=

# Semantic Scholar API key (https://www.semanticscholar.org/product/api).
# Works unauthenticated at a much lower rate limit if left blank.
SEMANTIC_SCHOLAR_API_KEY=

# NCBI E-utilities API key (https://www.ncbi.nlm.nih.gov/account/) for
# PubMed/bioRxiv lookups. Works unauthenticated (3 req/s instead of 10) if
# left blank -- NCBI_TOOL_EMAIL is still required by their usage policy even
# unauthenticated.
NCBI_API_KEY=
NCBI_TOOL_EMAIL=

# Reserved for a future Bluesky discourse-layer phase. Not required for
# read-only public search against the unauthenticated AppView API.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
