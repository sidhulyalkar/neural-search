<?xml version="1.0" encoding="UTF-8"?>
<neural_search_paper_upgrade_spec version="0.9">
  <project>
    <name>Neural Search</name>
    <core_thesis>
      Neural Search is not only a search engine for neuroscience datasets. It is a retrieval framework for reusable experimental contexts, where datasets are matched by typed scientific meaning, graph relationships, provenance, and analysis affordances.
    </core_thesis>
    <principles>
      <principle>Separate implemented work from proposed roadmap.</principle>
      <principle>Do not invent benchmark numbers.</principle>
      <principle>Use TODO or to-be-evaluated placeholders for experiments not yet run.</principle>
      <principle>Prefer defensible claims over grand claims.</principle>
      <principle>Make the benchmark protocol reproducible.</principle>
      <principle>Make graph edges provenance-aware and confidence-scored.</principle>
    </principles>
  </project>

  <paper_revision>
    <main_file>neural_search_whitepaper.tex</main_file>
    <appendix_source>neural_search_whitepaper.tex</appendix_source>
    <objectives>
      <objective>Transform the paper from a vision whitepaper into a credible systems and retrieval research paper.</objective>
      <objective>Add an evidence spine: claims, baselines, ablations, benchmark protocol, and failure taxonomy.</objective>
      <objective>Improve the related work and position against neuroscience repositories, metadata standards, hybrid IR, and graph retrieval.</objective>
      <objective>Clarify what is implemented, validated, partially implemented, proposed, and speculative.</objective>
    </objectives>
    <sections_to_add>
      <section name="Claim Status and Evidence">
        <purpose>Prevent overclaiming and clarify evidence level.</purpose>
        <items>
          <item>Hybrid metadata retrieval</item>
          <item>Hard-negative filtering</item>
          <item>Typed scientific label extraction</item>
          <item>Graph metapath search</item>
          <item>Analysis affordance search</item>
          <item>Latent neural signature search</item>
          <item>Cross-species alignment</item>
          <item>Causal claim graph</item>
        </items>
      </section>
      <section name="Benchmark Protocol">
        <items>
          <item>Corpus size</item>
          <item>Query categories</item>
          <item>Labeling rubric</item>
          <item>Annotator protocol</item>
          <item>Hard-negative definitions</item>
          <item>Bootstrap confidence interval method</item>
          <item>Baseline ladder</item>
          <item>Ablation matrix</item>
          <item>Error taxonomy</item>
        </items>
      </section>
      <section name="Retrieval as Three-Layer Scientific Matching">
        <layers>
          <layer name="surface_matching">Text, title, description, abstract, keywords, authors, and repository metadata.</layer>
          <layer name="experimental_context_matching">Species, modality, brain region, behavioral task, event labels, preparation, data format, perturbation, and analysis affordance.</layer>
          <layer name="relational_graph_matching">Typed graph paths connecting datasets, papers, tasks, brain regions, modalities, models, and analysis methods.</layer>
        </layers>
      </section>
      <section name="Standards-Aligned Provenance">
        <standards>
          <standard>PROV-O</standard>
          <standard>RO-Crate</standard>
          <standard>DataCite</standard>
          <standard>Schema.org Dataset</standard>
          <standard>Bioschemas</standard>
          <standard>LinkML</standard>
        </standards>
      </section>
      <section name="Analysis Affordance Predicates">
        <affordances>
          <affordance>choice_decoding</affordance>
          <affordance>q_learning</affordance>
          <affordance>state_space_modeling</affordance>
          <affordance>neural_behavior_alignment</affordance>
          <affordance>cross_session_analysis</affordance>
          <affordance>causal_perturbation_analysis</affordance>
          <affordance>representational_similarity_analysis</affordance>
        </affordances>
      </section>
      <section name="Future Experiments">
        <experiments>
          <experiment>baseline_ladder</experiment>
          <experiment>hard_negative_adversarial_benchmark</experiment>
          <experiment>affordance_validation</experiment>
          <experiment>cross_dataset_pairing</experiment>
          <experiment>metadata_robustness</experiment>
          <experiment>embedding_model_bakeoff</experiment>
          <experiment>graph_link_prediction</experiment>
          <experiment>latent_neural_signature_search</experiment>
          <experiment>causal_claim_graph</experiment>
          <experiment>human_in_the_loop_recommendation_study</experiment>
        </experiments>
      </section>
      <section name="Limitations">
        <items>
          <item>Small initial benchmark.</item>
          <item>Metadata extraction errors.</item>
          <item>Graph edge uncertainty.</item>
          <item>Incomplete analysis affordance predicates.</item>
          <item>Dense embedding overgeneralization.</item>
          <item>Curator or corpus bias.</item>
          <item>Latent neural search not yet broadly validated.</item>
        </items>
      </section>
    </sections_to_add>
  </paper_revision>

  <graph_schema>
    <node_types>
      <node>Dataset</node>
      <node>Paper</node>
      <node>Species</node>
      <node>BrainRegion</node>
      <node>Modality</node>
      <node>Task</node>
      <node>Event</node>
      <node>AnalysisAffordance</node>
      <node>Model</node>
      <node>DataStandard</node>
      <node>Software</node>
    </node_types>
    <edge_types>
      <edge>HAS_MODALITY</edge>
      <edge>RECORDED_FROM</edge>
      <edge>USES_TASK</edge>
      <edge>HAS_EVENT</edge>
      <edge>SUPPORTS_ANALYSIS</edge>
      <edge>DERIVED_FROM_PAPER</edge>
      <edge>VALIDATED_BY_SCHEMA</edge>
      <edge>SIMILAR_TASK_CONTEXT</edge>
      <edge>COMPARABLE_ACROSS_SPECIES</edge>
      <edge>BENCHMARKS_MODEL</edge>
      <edge>REQUIRES_METADATA</edge>
    </edge_types>
    <edge_metadata>
      <field>source</field>
      <field>evidence_text</field>
      <field>confidence</field>
      <field>extractor</field>
      <field>timestamp</field>
      <field>validation_status</field>
    </edge_metadata>
  </graph_schema>

  <experiment_roadmap>
    <experiment id="baseline_ladder" priority="1">
      <goal>Measure contribution of each retrieval layer.</goal>
      <systems>
        <system>keyword_search</system>
        <system>bm25</system>
        <system>field_weighted_bm25</system>
        <system>dense_only</system>
        <system>bm25_dense_rrf</system>
        <system>bm25_dense_ontology</system>
        <system>bm25_dense_ontology_graph</system>
        <system>full_neural_search</system>
      </systems>
      <metrics>
        <metric>precision_at_5</metric>
        <metric>recall_at_10</metric>
        <metric>mrr</metric>
        <metric>ndcg_at_10</metric>
        <metric>hard_negative_violation_rate</metric>
        <metric>latency</metric>
      </metrics>
    </experiment>
    <experiment id="hard_negative_adversarial_benchmark" priority="2">
      <goal>Test exclusion constraints and invalid-match prevention.</goal>
      <metrics>
        <metric>violation_rate_at_1</metric>
        <metric>violation_rate_at_5</metric>
        <metric>violation_rate_at_10</metric>
        <metric>violation_source_field</metric>
      </metrics>
    </experiment>
    <experiment id="affordance_validation" priority="3">
      <goal>Validate analysis affordance predictions against human labels or deterministic schema checks.</goal>
      <metrics>
        <metric>precision</metric>
        <metric>recall</metric>
        <metric>f1</metric>
        <metric>calibration_error</metric>
        <metric>false_affordance_rate</metric>
      </metrics>
    </experiment>
    <experiment id="cross_dataset_pairing" priority="4">
      <goal>Find scientifically useful dataset pairs.</goal>
      <metrics>
        <metric>pair_relevance</metric>
        <metric>reason_correctness</metric>
        <metric>graph_path_validity</metric>
        <metric>novelty_score</metric>
      </metrics>
    </experiment>
    <experiment id="metadata_robustness" priority="5">
      <goal>Measure retrieval degradation under missing or corrupted metadata.</goal>
      <metrics>
        <metric>p_at_5_delta</metric>
        <metric>ndcg_at_10_delta</metric>
        <metric>violation_increase</metric>
        <metric>graph_rescue_rate</metric>
      </metrics>
    </experiment>
  </experiment_roadmap>

  <agent_specs>
    <claude>
      <role>Rapid manuscript expansion, restructuring, and prose-level revision.</role>
      <strengths>
        <strength>Fast whole-document edits.</strength>
        <strength>Related work drafting.</strength>
        <strength>Table and section scaffolding.</strength>
        <strength>Making the paper read like a credible research submission.</strength>
      </strengths>
      <avoid>
        <item>Inventing experimental numbers.</item>
        <item>Overclaiming beyond implemented work.</item>
        <item>Adding unverifiable citations without TODO markers.</item>
      </avoid>
    </claude>
    <codex>
      <role>Slow, careful, feature-by-feature experiment implementation and testing.</role>
      <strengths>
        <strength>Evaluation pipeline implementation.</strength>
        <strength>Focused tests.</strength>
        <strength>Config-driven benchmark scaffolding.</strength>
        <strength>Report generation.</strength>
      </strengths>
      <avoid>
        <item>Large sweeping rewrites.</item>
        <item>Paper prose changes.</item>
        <item>Adding heavyweight dependencies without optional isolation.</item>
      </avoid>
    </codex>
  </agent_specs>
</neural_search_paper_upgrade_spec>
